{
	"info": {
		"name": "AquaSense Backend API",
		"description": "AquaSense TDS Backend — ทุก endpoint ที่ใช้งานได้",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		}
	],
	"item": [
		{
			"name": "Public — Auth",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "Login (somchai)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.success && json.data && json.data.token) {",
									"    pm.collectionVariables.set('token', json.data.token);",
									"    console.log('Token saved automatically');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"somchai@example.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "login"]
						},
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "Login (admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.success && json.data && json.data.token) {",
									"    pm.collectionVariables.set('token', json.data.token);",
									"    console.log('Admin token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "login"]
						},
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"display_name\": \"ทดสอบ ระบบ\",\n  \"email\": \"test@example.com\",\n  \"phone\": \"0811111111\",\n  \"birth_date\": \"1990-01-01T00:00:00Z\",\n  \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "register"]
						},
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "Social Login — Google",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"  var json = pm.response.json();",
									"  if (json.data && json.data.token) {",
									"    pm.collectionVariables.set('token', json.data.token);",
									"    console.log('Google token saved');",
									"  }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"provider\": \"google\",\n  \"id_token\": \"YOUR_GOOGLE_ID_TOKEN_HERE\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/social",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "social"]
						},
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "Social Login — Apple",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"  var json = pm.response.json();",
									"  if (json.data && json.data.token) {",
									"    pm.collectionVariables.set('token', json.data.token);",
									"    console.log('Apple token saved');",
									"  }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"provider\": \"apple\",\n  \"id_token\": \"YOUR_APPLE_ID_TOKEN_HERE\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/social",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "social"]
						},
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"header": [
