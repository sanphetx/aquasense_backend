							"path": ["api", "v1", "auth", "forgot-password"]
						},
						"auth": { "type": "noauth" }
					}
				}
			]
		},
		{
			"name": "Farms",
			"item": [
				{
					"name": "Get My Farm",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/farms",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "farms"]
						}
					}
				},
				{
					"name": "Create Farm",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"แปลงทดสอบ\",\n  \"area_size_rai\": 5.0,\n  \"crop_type\": \"rice\",\n  \"yield_ton_per_rai\": 0.8,\n  \"avg_price_baht_per_kg\": 9.5,\n  \"distribution_channels\": [\"สหกรณ์\"],\n  \"soil_ph\": 6.5,\n  \"soil_problems\": [\"ดินเปรี้ยว\"],\n  \"water_source\": \"น้ำฝน\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/farms",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "farms"]
						}
					}
				},
				{
					"name": "Update Farm Location",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"latitude\": 14.88,\n  \"longitude\": 100.99\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/farms/f001/location",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "farms", "f001", "location"]
						}
					}
				},
				{
					"name": "Link Sensor to Farm",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"sensor_id\": \"s001\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/farms/f001/sensor",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "farms", "f001", "sensor"]
						}
					}
				}
			]
		},
